{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "busy2free configuration",
    "type": "object",
    "properties": {
        "sources": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "url": {
                        "type": "string",
                        "format": "uri"
                    },
                    "searchWindow": {
                        "$ref": "#/definitions/searchWindow"
                    },
                    "minDurationMinutes": {
                        "type": "integer",
                        "minimum": 1
                    }
                },
                "required": [
                    "name",
                    "url"
                ]
            }
        },
        "searchWindow": {
            "allOf": [
                {
                    "$ref": "#/definitions/searchWindow"
                },
                {
                    "required": [
                        "end",
                        "weekdays",
                        "weekends"
                    ]
                }
            ]
        },
        "minDurationMinutes": {
            "type": "integer",
            "minimum": 1
        },
        "slotStepMinutes": {
            "type": "integer",
            "minimum": 1
        },
        "outputs": {
            "type": "object",
            "properties": {
                "ics": {
                    "type": "string"
                },
                "json": {
                    "type": "string"
                }
            },
            "required": [
                "ics",
                "json"
            ]
        },
        "timeZone": {
            "type": "string",
            "description": "The time zone used to define search windows and JSON output (e.g., America/Los_Angeles)."
        }
    },
    "required": [
        "sources",
        "searchWindow",
        "minDurationMinutes",
        "slotStepMinutes",
        "outputs",
        "timeZone"
    ],
    "definitions": {
        "hourRange": {
            "type": "object",
            "properties": {
                "startHour": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 23
                },
                "endHour": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 24
                }
            }
        },
        "searchWindow": {
            "type": "object",
            "properties": {
                "start": {
                    "type": "string",
                    "format": "date-time",
                    "description": "Start date for the search window. (default: today)"
                },
                "end": {
                    "type": "string",
                    "format": "date-time",
                    "description": "End date for the search window."
                },
                "weekdays": {
                    "allOf": [
                        {
                            "$ref": "#/definitions/hourRange"
                        }
                    ]
                },
                "weekends": {
                    "allOf": [
                        {
                            "$ref": "#/definitions/hourRange"
                        }
                    ]
                }
            }
        }
    }
}
